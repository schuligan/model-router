# ─────────────────────────────────────────────────────────────────────────────
# Optional configuration.
#
# THE ROUTER ITSELF NEEDS NONE OF THIS. Core routing is pure local logic — no
# network, no key. These vars only enable the OPTIONAL live "explain" mode
# (roadmap), where a model narrates the trade-off in prose.
#
# Copy to .env and fill in only if you opt into that mode. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic API key — only for the optional live "explain" mode.
# Get one from your provider console. Keep it secret.
ANTHROPIC_API_KEY=

# Model used for the optional explain narration (defaults to a cheap/fast model).
MODEL_ROUTER_EXPLAIN_MODEL=claude-haiku-4-5
